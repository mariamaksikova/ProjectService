# Используем официальный образ Python 3.11 (slim-версия для минимального размера)
FROM python:3.11-slim

# Устанавливаем рабочую директорию внутри контейнера
# Все последующие команды будут выполняться в этой папке
WORKDIR /app

# Копируем файл с зависимостями (сначала только его!)
# Это делается до копирования кода, чтобы использовать кэширование слоёв
COPY requirements.txt .

# Устанавливаем зависимости внутри контейнера
# --no-cache-dir не сохраняет кэш pip, чтобы образ был меньше
RUN pip install --no-cache-dir -r requirements.txt

# ВАЖНО: код НЕ копируется в образ!
# Мы будем использовать bind mount при разработке, чтобы не пересобирать образ
# при каждом изменении кода. Для продакшена код нужно копировать.

# Команда для запуска приложения
# --host 0.0.0.0 - слушаем все сетевые интерфейсы внутри контейнера
# --port 8000 - стандартный порт для разработки
# --reload - автоматический перезапуск при изменениях кода (только для разработки!)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
